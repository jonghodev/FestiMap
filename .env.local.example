# ===========================
# FestiMap Environment Variables
# ===========================

# Kakao Map JavaScript SDK App Key
# Get from: https://developers.kakao.com > My Application > App Keys > JavaScript Key
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_javascript_app_key_here

# Database (PostgreSQL on RDS)
DATABASE_URL=postgresql://user:password@host:5432/festimap?schema=festimap

# JWT Secret (min 32 chars)
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# Anthropic Claude API (for future AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# 공공 API 키 (선택 - npm run events:fetch)
# ─────────────────────────────────────────

# 한국관광공사 TourAPI 4.0
# 발급: https://www.data.go.kr/data/15101578/openapi.do
TOUR_API_KEY=

# 서울 열린데이터광장 문화행사 API
# 발급: https://data.seoul.go.kr/dataList/OA-15105/S/1/datasetView.do
SEOUL_OPEN_DATA_KEY=
