# ===========================
# FestiMap 환경변수 설정
# ===========================
# 이 파일을 .env.local로 복사하고 실제 값으로 채워주세요.
# cp .env.local.example .env.local

# ─────────────────────────────────────────
# Kakao Map API
# ─────────────────────────────────────────
# JavaScript App Key (지도 표시 - 브라우저에 노출됨)
# 발급: https://developers.kakao.com > 내 애플리케이션 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_javascript_app_key_here

# REST API Key (서버사이드용)
# 발급: https://developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# ─────────────────────────────────────────
# 데이터베이스
# ─────────────────────────────────────────
# 로컬 개발: SQLite 사용
DATABASE_URL=file:./prisma/dev.db
# 프로덕션 (PostgreSQL on AWS RDS):
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR-RDS-HOST:5432/festimap?schema=festimap

# ─────────────────────────────────────────
# 인증
# ─────────────────────────────────────────
# JWT 서명 비밀키 (최소 32자, 아래 명령으로 생성)
# openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars

# ─────────────────────────────────────────
# Anthropic Claude API (AI 기능용)
# ─────────────────────────────────────────
# 발급: https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────
# 앱 URL
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────
# 공공 API 키 (선택 - npm run events:fetch에서 사용)
# ─────────────────────────────────────────

# 한국관광공사 TourAPI 4.0
# 발급: https://www.data.go.kr/data/15101578/openapi.do
# (공공데이터포털 회원가입 후 활용신청 → 자동승인)
TOUR_API_KEY=

# 서울 열린데이터광장 문화행사 API
# 발급: https://data.seoul.go.kr/dataList/OA-15105/S/1/datasetView.do
SEOUL_OPEN_DATA_KEY=
