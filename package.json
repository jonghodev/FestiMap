{
  "name": "festimap",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:prod:generate": "prisma generate --schema=prisma/schema.production.prisma",
    "db:prod:migrate": "prisma migrate deploy --schema=prisma/schema.production.prisma",
    "events:fetch": "tsx scripts/fetch-public-events.ts",
    "events:collect": "tsx scripts/collect-events.ts",
    "events:normalize": "tsx scripts/normalize-seed-events.ts",
    "events:validate": "tsx scripts/transform-validate-events.ts",
    "db:seed:pipeline": "tsx scripts/seed-with-transform.ts",
    "db:seed:validated": "tsx scripts/seed-from-validated.ts",
    "db:seed:reset": "tsx scripts/seed-from-validated.ts --reset",
    "db:seed:dry-run": "tsx scripts/seed-from-validated.ts --dry-run",
    "db:prod:seed": "tsx scripts/seed-production.ts",
    "db:prod:seed:dry-run": "tsx scripts/seed-production.ts --dry-run",
    "db:prod:seed:reset": "tsx scripts/seed-production.ts --reset"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "lucide-react": "^1.7.0",
    "next": "^15.3.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
