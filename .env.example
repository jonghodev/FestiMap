# Database (PostgreSQL on AWS RDS)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/festimap?schema=festimap"

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-secret-key-here"

# Kakao Map JavaScript API Key
NEXT_PUBLIC_KAKAO_MAP_API_KEY="your-kakao-map-api-key"

# Anthropic API Key (Claude Haiku for chat features)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
