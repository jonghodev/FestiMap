# ===========================
# FestiMap Environment Variables
# ===========================
# 프로덕션용 환경변수 템플릿 (Vercel에 설정)
# Vercel Dashboard > Settings > Environment Variables

# ─────────────────────────────────────────
# Kakao Map API
# ─────────────────────────────────────────
# JavaScript App Key (브라우저 노출)
# 발급: https://developers.kakao.com > 내 애플리케이션 > 앱 키 > JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_APP_KEY="your-kakao-javascript-app-key"

# REST API Key (서버사이드)
# 발급: https://developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY="your-kakao-rest-api-key"

# ─────────────────────────────────────────
# 데이터베이스 (PostgreSQL on AWS RDS)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-RDS-HOST:5432/festimap?schema=festimap"

# ─────────────────────────────────────────
# 인증
# ─────────────────────────────────────────
# JWT 서명 비밀키 (최소 32자)
# 생성: openssl rand -base64 32
JWT_SECRET="your-secret-key-here"

# ─────────────────────────────────────────
# Anthropic Claude API
# ─────────────────────────────────────────
# 발급: https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─────────────────────────────────────────
# 앱 URL
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://festimap.vercel.app"

# ─────────────────────────────────────────
# 공공 API 키 (선택사항 - events:fetch 스크립트에서 사용)
# ─────────────────────────────────────────

# 한국관광공사 TourAPI 4.0 인증키
# 발급: https://www.data.go.kr/data/15101578/openapi.do
# (공공데이터포털 회원가입 후 활용신청 → 자동승인)
TOUR_API_KEY=""

# 서울 열린데이터광장 API 키
# 발급: https://data.seoul.go.kr/dataList/OA-15105/S/1/datasetView.do
SEOUL_OPEN_DATA_KEY=""
